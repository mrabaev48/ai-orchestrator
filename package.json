{
  "name": "ai-orchestrator",
  "version": "1.0.0",
  "description": "AI Orchestrator MVP foundation",
  "type": "module",
  "scripts": {
    "bootstrap": "tsx apps/control-plane/src/cli.ts bootstrap",
    "analyze-architecture": "tsx apps/control-plane/src/cli.ts analyze-architecture",
    "plan-backlog": "tsx apps/control-plane/src/cli.ts plan-backlog",
    "generate-docs": "tsx apps/control-plane/src/cli.ts generate-docs",
    "assess-release": "tsx apps/control-plane/src/cli.ts assess-release",
    "check-state": "tsx apps/control-plane/src/cli.ts check-state",
    "prepare-export": "tsx apps/control-plane/src/cli.ts prepare-export",
    "run-cycle": "tsx apps/control-plane/src/cli.ts run-cycle",
    "show-state": "tsx apps/control-plane/src/cli.ts show-state",
    "export-backlog": "tsx apps/control-plane/src/cli.ts export-backlog",
    "dashboard-api:start": "tsx apps/dashboard-api/src/main.ts",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm test",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "turbo": "node scripts/turbo-runner.mjs",
    "turbo:lint": "node scripts/turbo-runner.mjs run lint",
    "turbo:test": "node scripts/turbo-runner.mjs run test",
    "turbo:typecheck": "node scripts/turbo-runner.mjs run typecheck",
    "turbo:build": "node scripts/turbo-runner.mjs run build",
    "worker:start": "tsx apps/worker/src/main.ts",
    "test:baseline-invariants": "node --import tsx --test tests/baseline-invariants-regression.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.1.16",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
