{
  "name": "ai-orchestrator",
  "version": "1.0.0",
  "description": "AI Orchestrator MVP foundation",
  "type": "module",
  "scripts": {
    "bootstrap": "tsx apps/control-plane/src/cli.ts bootstrap",
    "analyze-architecture": "tsx apps/control-plane/src/cli.ts analyze-architecture",
    "plan-backlog": "tsx apps/control-plane/src/cli.ts plan-backlog",
    "generate-docs": "tsx apps/control-plane/src/cli.ts generate-docs",
    "assess-release": "tsx apps/control-plane/src/cli.ts assess-release",
    "check-state": "tsx apps/control-plane/src/cli.ts check-state",
    "prepare-export": "tsx apps/control-plane/src/cli.ts prepare-export",
    "run-cycle": "tsx apps/control-plane/src/cli.ts run-cycle",
    "show-state": "tsx apps/control-plane/src/cli.ts show-state",
    "export-backlog": "tsx apps/control-plane/src/cli.ts export-backlog",
    "dashboard-api:start": "tsx apps/dashboard-api/src/main.ts",
    "worker:start": "tsx apps/worker/src/main.ts",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "boundaries": "tsx scripts/check-package-boundaries.ts",
    "lint": "turbo run lint && eslint scripts tests",
    "lint:fix": "turbo run lint -- --fix && eslint scripts tests --fix",
    "typecheck": "turbo run typecheck && tsc -b scripts/tsconfig.json tests/tsconfig.json --pretty false",
    "build": "turbo run build",
    "check": "pnpm run boundaries && pnpm run lint && pnpm run typecheck && pnpm run test",
    "test": "turbo run test && node --import tsx --test \"tests/**/*.test.ts\"",
    "test:baseline-invariants": "node --import tsx --test tests/baseline-invariants-regression.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.1.16",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "turbo": "^2.9.9",
    "@ai-orchestrator/agents": "workspace:*",
    "@ai-orchestrator/application": "workspace:*",
    "@ai-orchestrator/control-plane": "workspace:*",
    "@ai-orchestrator/core": "workspace:*",
    "@ai-orchestrator/dashboard-api": "workspace:*",
    "@ai-orchestrator/execution": "workspace:*",
    "@ai-orchestrator/llm": "workspace:*",
    "@ai-orchestrator/prompts": "workspace:*",
    "@ai-orchestrator/shared": "workspace:*",
    "@ai-orchestrator/state": "workspace:*",
    "@ai-orchestrator/tools": "workspace:*",
    "@ai-orchestrator/worker": "workspace:*",
    "@ai-orchestrator/workflow": "workspace:*"
  },
  "packageManager": "pnpm@10.13.1"
}
