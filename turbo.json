{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "//#boundaries": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^build",
        "//#boundaries"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "typecheck"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": [
        "^build",
        "typecheck"
      ],
      "outputs": [
        "dist/**"
      ]
    }
  }
}
