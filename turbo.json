{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "lint"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "typecheck"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": [
        "test",
        "baseline-invariants"
      ],
      "outputs": []
    },
    "baseline-invariants": {
      "dependsOn": [
        "typecheck"
      ],
      "outputs": []
    }
  }
}
